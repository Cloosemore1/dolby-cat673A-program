//This seems to reformat the block into the printmaster format
$027C: MOVE     #2B3700,X0
$027E: MOVE     X0,X:(R1)+          //First 2 bytes of "printmaster" block are 0x2B37
$027F: MOVE     #693800,B           //Second 2 bytes of "printmaster" block are 0x6938
$0281: MOVE     #000200,Y0
$0283: MOVE     #0003FF,Y1
$0285: MOVE     #001127,R0
$0287: MOVE     #0000FE,N1
$0289: MOVE     X:(R0)+,X0          //Loads first index
$028A: DO       N1,$0299            //Runs this loop 254 times
$028C: MPY      Y0,X0,A B1,X:(R1)+  //Bit shift index 14 bits to the right, loads B1 into the output block location
$028D: AND      Y1,A
$028E: TFR      Y1,A    A1,N3       //N3 contains the upper 10 bits of the index, A now contains $0003FF
$028F: AND      X0,A    #FF0000,B1  //A contains the bottom 10 bits of the index
$0291: MOVE     X:(R3+N3),X1        //X1 contains the byte at the "upper index"
$0292: AND      X1,B    A1,N3       //Retain only the MSB of X1, load address offset register with "lower" index
$0293: MOVE     #008000,X1          
$0295: MOVE     X:(R3+N3),X0        //X0 contains the byte at the "upper index"
$0296: MPY      X1,X0,A #00FF00,X1  //Bit shift X0 1 byte to the right
$0298: AND      X1,A                //Retain only the middle byte
$0299: ADD      A,B     X:(R0)+,X0  //B now contains the bytes at the "upper" and "lower" indices, respectively 0xFFFF00, loads next index
$029A: MOVE     B1,X:(R1)+
$029B: RTS


