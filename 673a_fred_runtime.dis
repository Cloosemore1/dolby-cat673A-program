//Error Correction Input Block Subroutine @ $0132
$0132: MOVE     #00,R5              //Erasure count starts at 0
$0133: MOVE     X:(R0)+,N3
$0134: DO       N1,$013C            //Loop executes N1 times, where N1 is the number of bytes in the ECC block
$0136: MOVE     X:(R3+N3),B
$0137: MOVE     X:(R0)+,N3
$0138: JCLR     #15,B1,$013B        //Erasure indicator for current byte of data. Active high
$013A: MOVE     (R5)+               //Increment erasure counter accordingly
$013B: MOVE     B1,Y:$FFE0          //Input B1 to AHA4011B
$013D: RTS

//Error Correction Read Corrected Block Subroutine @ $013E
$013E: CLR      A       #01,X0
$013F: MOVE     A,Y1
$0140: MOVE     #14,N0
$0141: MOVE     #FF,X1
$0142: JCLR     #8,X:<<$FFE4,$014B  //If current message block was correctable, jump to $014B
$0144: DO       N1,$0148
$0146: MOVE     (R0)+
$0147: MOVE     Y:$FFE0,B
$0149: BSET     #23,Y1
$014A: JMP      $154
$014B: DO       N1,$0153
$014D: MOVE     X:(R0)+,N3
$014E: MOVE     Y:$FFE0,B
$0150: BCLR     #15,B1
$0151: JCC      $153
$0152: ADD      X0,A 
$0153: MOVE     B1,X:(R3+N3)
$0154: MOVE     R5,X0
$0155: LUA      (R0)-N0,R5
$0156: MOVE     #008000,X1
$0158: MPY      +X1,X0,B        X:(R5)+,N3
$0159: MOVE     B0,B
$015A: OR       Y1,B
$015B: MOVE     B1,X:(R3+N3)
$015C: MOVE     X:(R5),N3
$015D: NOP
$015E: MOVE     A1,X:(R3+N3)
$015F: RTS

//Film Block Error Correction Subroutine @ $0200
//Perform first layer of error correction
$0200: CLR      A 
$0201: MOVE     A,X:(R3)
$0202: BCLR     #3,X:<<$FFE4        //Reset AHA4011B and begin initialization for first layer of ECC
$0203: MOVEP    #D30000,Y:<<$FFE0   //Set Erasure Multiplier
$0205: MOVEP    #940000,Y:<<$FFE0   //Set Error Threshold
$0207: MOVEP    #940000,Y:<<$FFE0   //Set Check Bytes - 20
$0209: MOVEP    #430000,Y:<<$FFE0   //Set Message Bytes - 67
$020B: MOVEP    #570000,Y:<<$FFE0   //Set Block Length - 87
$020D: MOVEP    #2C0000,Y:<<$FFE0   //Set Control Byte
