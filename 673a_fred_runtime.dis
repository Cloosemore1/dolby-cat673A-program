$0210: MOVE     #000057,N1
$0212: MOVE     #000C5C,R0
$0214: JSR      $132                //Clock first message block into AHA4011B
$0215: MOVE     R5,Y:$02            //Store number of erasures
$0216: MOVE     #000CB3,R0
$0218: JSR      $132                //Clock next message block into AHA4011B
$0219: MOVE     R5,Y:$03
$021A: MOVE     #000C5C,R0
