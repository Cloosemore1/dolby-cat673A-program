$00AE: CMP      X0,B
$00AF: JNE      $0AD
$00B0: MOVE     B,X:(R0)
$00B1: LUA      (R1)-,R0
$00B2: TFR      Y0,A    #F8,X0
$00B3: CMP      X0,A    #00,X0
$00B4: JNE      $0B6
$00B5: MOVE     X1,X0
$00B6: MOVE     X0,X:(R0)
$00B7: ADD      X1,B    X:(R1)+,X0
$00B8: CMP      X0,B
$00B9: JNE      $0B7
$00BA: MOVE     B,X0
$00BB: LUA      (R1)-,R0
$00BC: MOVE     #003902,R1
$00BE: MOVE     #000800,X1
$00C0: CLR      A       X:(R1)+,X0
$00C1: REP      3FE
$00C2: ADD      X0,A    X:(R1)+,X0
$00C3: MOVE     #000FFF,Y0
$00C5: AND      Y0,A    A1,X0
$00C6: MPY      +X1,X0,A        A1,X:$3900
$00C8: AND      Y0,A
$00C9: MOVE     A1,X:$3901
$00CB: MOVE     #0C,R1
$00CC: MOVE     #003900,N1
$00CE: DO       #3F4,$0132
$00D0: MOVE     X:(R1+N1),A
$00D1: JSET     #23,A1,$0132
$00D3: MOVE     R1,X0
$00D4: CMP      X0,A
$00D5: JEQ      $132
$00D6: MOVE     X0,X:$02
$00D7: JSR      $1C4
$00D8: MOVE     #04,N0
$00D9: MOVE     #0000FF,X1
$00DB: LUA      (R0)+N0,R4
$00DC: NOP
$00DD: MOVE     Y:(R4)+,A
$00DE: AND      X1,A    Y:(R4),B
$00DF: AND      X1,B    A1,Y0
$00E0: ASL      B
$00E2: MPY      -X1,Y0,A    B1,X1
$00E3: MOVE     A0,A
$00E4: SUB      Y0,A
$00E5: SUB      X1,A
$00E6: MOVE     A,Y:$01
$00E7: MOVE     #0000FF,Y1
$00E9: MOVE     Y:$01,B
$00EA: JCLR     #3,X:$00,$00EE
$00EC: JCLR     #4,X:$00,$00F0
$00EE: MOVE     #80,N0
$00EF: JMP      $0F6
$00F0: MOVE     #7F,N0
$00F1: NOP
$00F2: MOVE     Y:(R0+N0),A
$00F3: AND      Y1,A
$00F4: MOVE     A1,N0
$00F5: JEQ      $0FB
$00F6: MOVE     Y:(R0)+,A
$00F7: DO       N0,$00FA
$00F9: AND      Y1,A
$00FA: ADD      A,B     Y:(R0)+,A
$00FB: MOVE     B1,Y:$01
$00FC: JSET     #3,X:$00,$0100
$00FE: JSR      $1EA
$00FF: JMP      $0E9
$0100: CLR      A       X:$02,X0
$0101: MOVE     #C0,A1
$0102: CMP      X0,A    #00,B2
$0103: JEQ      $132
$0104: MOVE     #00FFFF,X1
$0106: AND      X1,B
$0107: JEQ      $10B
$0108: BSET     #5,X:$00
$0109: BSET     #0,X:$00
$010A: JMP      $10C
$010B: BCLR     #5,X:$00
$010C: JSR      $1C4
$010D: MOVE     #02,N0
