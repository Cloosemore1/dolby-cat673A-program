$0113: MOVE     A0,A
$0114: AND      X1,A    #03,N0
$0115: MOVE     #003D00,R2
$0117: MOVE     Y:(R0+N0),Y0
$0118: MOVE     #0000FF,Y1
$011A: TFR      Y1,A    A1,Y1
$011B: AND      Y0,A    #03,N2
$011C: ADD      Y1,A
$011D: MOVE     A1,Y0
$011E: JCLR     #5,X:$00,$0121
$0120: BSET     #23,Y0
$0121: DO       Y:$00,$012B
$0123: MOVE     X:(R2),A
$0124: AND      X1,A
$0125: CMP      Y1,A
$0126: JNE      $12B
$0127: MOVE     Y0,X:(R2)+
$0128: MOVE     X0,X:(R2)
$0129: ENDDO
$012A: JMP      $132
$012B: MOVE     (R2)+N2
$012C: MOVE     Y0,X:(R2)+
$012D: CLR      A       X0,X:(R2)+
$012E: MOVE     #01,A1
$012F: CLR      B       Y:$00,Y0
$0130: ADD      Y0,A    B,X:(R2)
$0131: MOVE     A1,Y:$00
$0132: MOVE     (R1)+
$0133: CLR      A       X:$3D0D,X0
$0135: CMP      X0,A    X:$3D0C,X1
$0137: JEQ      $13A
$0138: JCLR     #23,X1,$0166
$013A: MOVEP    #00C000,X:<<$FFF2
$013C: MOVEP    #000302,X:<<$FFF0
$013E: MOVEP    #0001FF,X:<<$FFE1
$0140: BCLR     #7,X:$0001
$0142: MOVEP    X:$0001,Y:<<$FFE2
$0144: MOVE     #00,N0
$0145: MOVE     #33,R0
$0146: BCLR     #14,X:<<$FFE4
$0147: JSR      $1A6
$0148: BSET     #14,X:<<$FFE4
$0149: JSR      $19F
$014A: MOVEP    #0000F1,X:<<$FFF4
$014C: JCLR     #1,X:<<$FFF1,$014C
$014E: MOVEP    #000098,X:<<$FFF4
$0150: JCLR     #0,X:<<$FFF1,$0150
$0152: BCLR     #7,X:$0001
$0154: MOVEP    X:$0001,Y:<<$FFE2

//Second Stage Loader Not Found Error Display @ $156
//This block flashes H-E-L-P- -0- repeatedly on the 7 segment display and toggles the AHA4011 RSTN pin
//According to DA-20 manual, this error code means "Second stage loader not found"
$0156: MOVE     #30,R0
$0157: JSR      $1A6                //Display 'H' and delay ~300ms
$0158: MOVE     #2E,R0
$0159: JSR      $1A6                //Display 'E' and delay
$015A: MOVE     #31,R0
$015B: JSR      $1A6                //Display 'L' and delay
$015C: MOVE     #32,R0
$015D: JSR      $1A6                //Display 'P' and delay
$015E: MOVE     #35,R0
$015F: JSR      $1A6                //Display ' ' and delay
$0160: MOVE     #20,R0
$0161: JSR      $1A6                //Display '0' and delay
$0162: MOVE     #35,R0
$0163: JSR      $1A6                //Display ' ' and delay
$0164: JSR      $19F                //Delay ~300ms
$0165: JMP      $156                //Loop infinitely

//If second stage loader found, load it into program RAM starting at $5E0E
$0166: JSR      $1C4
$0167: MOVE     #000006,N0
$0169: MOVE     #000080,X1
$016B: MOVE     (R0)+N0
$016C: MOVE     #0000FF,Y0
$016E: MOVE     Y:(R0)+,A
$016F: AND      Y0,A    Y:(R0)+,B
$0170: AND      Y0,B    A1,X0
$0171: MOVE     B1,A0
$0172: MAC      +X1,X0,A        Y:(R0)+,B
$0173: AND      Y0,B    A0,R1
$0174: MOVE     Y:(R0)+,A
$0175: AND      Y0,A    B1,X0
$0176: MOVE     A1,B0
$0177: MAC      +X1,X0,B        #008000,Y1
$0179: MOVE     R1,R2
$017A: MOVE     Y:(R0)+,A
$017B: DO       B0,$0183            //This loop writes the second stage loader into program RAM from the ROM
$017D: AND      Y0,A    Y:(R0)+,B
$017E: AND      Y0,B    A1,X0
$017F: MAC      +X0,Y1,A        B1,X0
$0180: MAC      +X1,X0,A        Y:(R0)+,B
$0181: AND      Y0,B    A0,A
$0182: ADD      A,B     Y:(R0)+,A
$0183: MOVEM    B1,P:(R1)+

//Program RAM at R1 now contains 0xXXXXXX from Y:$660A, 660B, and 660C, respectively - little endian encoding
//This is the reverse of how the DSP56002 bootloader program functions!

$0184: JMP      P:(R2)              //Start execution of the second stage loader program

//FactoryTest of Freq Synth - DIP switch mode 'A' @ $185
//This code is executed only if the DIP switch is set to 'A' on startup, loops infinitely
//Toggles the AHA4011 RSTN pin, then displays the current DIP switch value on the 7 segment display
$0185: BCHG     #3,X:<<$FFE4        //Toggle AHA4011 RSTN pin
$0186: MOVEP    Y:<<$FFE2,X0        //Read current value of rotary switch
$0187: MOVE     #000080,X1          
$0189: MPY      X1,X0,A #F0,X1      //Multiply 0x000080 and X0 (this acts like bit shifting X0 16 bits to the right), store in A
$018A: MOVE     A0,A                
$018B: AND      X1,A    #000800,X1  //Retain only bits 7-4 of A1 (presumably some other peripheral information) 
$018D: MPY      X1,X0,A A1,Y:$FFE1  //Multiply 0x800 and X0 (this acts like bit shifting X0 12 bits to the right), store in A
$018F: MOVE     A1,X0
$0190: JSR      $192                //Call 7 segment display subroutine - will display whatever is currently selected on the DIP switch
$0191: JMP      $185                //Infinite loop

//7 Segment Display Control Subroutine @ $0192
$0192: MOVE     #00000F,A
$0194: AND      X0,A    #20,R0      //Utilize bottom 4 bits of X0 to determine data offset, load base address to R0
$0195: MOVE     A,N0
$0196: MOVE     #0001FF,X0          
$0198: MOVE     X:$01,A             //Load accumulator with previous 7 segment display value
$0199: AND      X0,A
$019A: MOVEM    P:(R0+N0),X0        //R0 is the start of 7 segment display data - N0 is the character to be displayed
$019B: ADD      X0,A
$019C: MOVE     A1,X:$01            //Stores the new 7 segment data and previous other data back to X memory
$019D: MOVEP    A1,Y:<<$FFE2        //Display new character on 7 segment display
$019E: RTS

//Delay Subroutine @ $019F
//Produces an approximately 300ms delay by toggling AHA4011 RSTN 4,914,900 times
$019F: MOVE     #003FFF,X1          //X1 = 16383 decimal 
$01A1: DO       #12C,$01A4          //Hardware loop - execute through $01A4 300 times
$01A3: REP      X1                  //Repeat next instruction 16383 times
$01A4: BCHG     #3,X:<<$FFE4        //Toggle AHA4011 RSTN
$01A5: RTS

//7 Segment Display Update w/ Delay Subroutine @ $01A6
$01A6: JSR      $196                //7 Segment display using program memory at R0
$01A7: JMP      $19F                //Delay subroutine, since PC was not pushed to LR, delay subroutine RTS returns from this as well

//Subroutine at $1A8 - no clue what this does. Possibly checksums the flash ROM?
$01A8: MOVE     #0000FF,Y1          //Bit mask
$01AA: MOVE     #000FFF,Y0          //Bit mask
$01AC: MOVE     #000080,X1          //Multiplication factor?
$01AE: MOVE     #006000,R0          //Load R0 with Y memory start address
$01B0: MOVE     #003900,R1          //Load R1 with X memory start address

$01B2: DO       #200,$01C2          //Hardware loop - $01B4 to 01C2 will execute 512 times
$01B4: MOVE     Y:(R0)+,A           //Load Y memory starting at $6000 into A1
$01B5: AND      Y1,A    Y:(R0)+,B   //Mask out LSB from A1, load B1 with the next address in Y memory
$01B6: AND      Y1,B    A1,X0       //Mask out LSB from B1, load A1 into X0
//A1 contains 0x0000XX from Y:$6000, B1 contains 0x0000XX from Y:$6001
$01B7: MOVE     B1,A0               //Load B1 into A0 - Accumulator A now contains the LSBs of Y:R0 in A1, and Y:R0+1 in A0
//A contains 0x0000XX0000XX from Y:$6000 and 6001, respectively
$01B8: MAC      X1,X0,A Y:(R0)+,B   //Add 0x80 * LSB of Y:R0 to A, load next Y address into B  NOTE: this is a two's complement fractional multiply
//This acts like shifting A1 16 bits to the right, and adding it back to A.
//A contains 0x0000XX00XXXX, Y:$6000 Y:$6000 and Y:$6001, respectively
$01B9: AND      Y1,B    A0,X0       //Mask out LSB from B1, load A0 into X0
//B1 contains 0x0000XX from Y:$6002, X0 contains 0x00XXXX from Y:$6000 and Y:$6001 respectively
$01BA: TFR      X1,B    B1,A0       //Move X1 into B1, Move B1 into A0
//B contains 0x000080000000, A now contains 0x0000XX0000XX from Y:$6000 and Y:$6002, respectively
$01BB: MAC      X1,X0,A #000800,X1  //Add 0x80 * X0 to A, move 0x800 into X1
//This acts like shifting X0 16 bits to the right and adding to A
//A contains 0x0000XX XXXXXX from Y:$6000, Y:$6000, Y:$6001, Y:$6002, respectively
$01BD: MOVE     A0,A                //Move A0 into A1
//A contains 0xXXXXXX XXXXXX, where XXXXXX is the LSB of Y:$6000 - $6002
$01BE: AND      Y0,A    A1,X0       //Mask Lower 12 bits from A1, move A1 into X0
//X0 contains XXXXXX is the LSB of Y:$6000 - $6002
//A1 contains 000XXX
$01BF: MPY      X1,X0,B B,X1        //Multiply 0x800 and X0, store in B, load B1 into X1
//Acts as a shift right by 12 bits for X0, stores into B
//B contains 0x000XXX XXX000
$01C0: AND      Y0,B                //Mask lower 12 bits from B1
//B1 contains 0x000XXX where 
$01C1: MOVE     B,X:(R1)+           //Move B1 into X memory starting at 3900
//X:$3900 contains the 
$01C2: MOVE     A,X:(R1)+           //Move A1 into X memory at the next address

$01C3: RTS                          //Return from subroutine

//Subroutine at $1C4, do not know what this does
$01C4: MOVE     X0,R0
$01C5: MOVE     #003900,N0
$01C7: CLR      A 
$01C8: MOVE     X:(R0+N0),A1
$01C9: BCLR     #23,X:(R0+N0)
$01CA: BCLR     #23,A1
$01CB: TST      A       #000001,X1
$01CD: JNE      $1D1
$01CE: BSET     #3,X:$00
$01CF: BCLR     #4,X:$00
$01D0: JMP      $1D7
$01D1: CMP      X1,A 
$01D2: JNE      $1D6
$01D3: BSET     #3,X:$00
$01D4: BSET     #4,X:$00
$01D5: JMP      $1D7
$01D6: BCLR     #3,X:$00
$01D7: MOVE     #000300,A
$01D9: MOVE     #FFFFFC,X1
$01DB: AND      X0,A    X:$FFE4,B
$01DD: AND      X1,B    A,X1    #008000,Y0
$01DF: MAC      +X1,Y0,B        #0000FF,A
$01E1: MOVEP    B1,X:<<$FFE4
$01E2: AND      X0,A    #000040,X1
$01E4: MOVE     A1,Y0
$01E5: MOVE     #006000,A0
$01E7: MAC      +X1,Y0,A 
$01E8: MOVE     A0,R0
$01E9: RTS

//Subroutine at $1EA, do not know what this does
$01EA: MOVE     #003900,R0
$01EC: MOVE     X0,N0
$01ED: NOP
$01EE: CLR      A       X:(R0+N0),X0
$01EF: BCLR     #23,X0
$01F0: CMP      X0,A    #01,A1
$01F1: JEQ      $1F4
$01F2: CMP      X0,A 
$01F3: JNE      $1C4
$01F4: RTS

//End of program - zero padded
$01F5: data 000000
$01F6: data 000000
$01F7: data 000000
$01F8: data 000000
$01F9: data 000000
$01FA: data 000000
