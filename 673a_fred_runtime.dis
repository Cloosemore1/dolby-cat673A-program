$0251: JSR      $13E

//Perform second layer of error correction
$0252: BCLR     #3,X:<<$FFE4        //Reset AHA4011B and begin initialization for second layer of ECC
$0253: MOVEP    #D90000,Y:<<$FFE0   //Set Erasure Multiplier
$0255: MOVEP    #940000,Y:<<$FFE0   //Set Error Threshold
